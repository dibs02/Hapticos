{
  "name": "hapticos",
  "displayName": "Hapticos - haptics for the web",
  "version": "0.0.1",
  "description": "A browser extension that adds haptic-style feedback to clicks and interactions",
  "author": "Dibyajyoti Ganguly",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.13",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "web_accessible_resources": [
      {
        "matches": [
          "http://*/*",
          "https://*/*"
        ],
        "resources": [
          "sounds/*"
        ]
      }
    ]
  }
}
